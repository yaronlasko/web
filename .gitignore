# This repo publishes ONLY the World Cup site + the pipeline that builds it.
# Everything else in the parent Polymarket-accuracy project is ignored by default
# (the catch-all `/*` below also covers .venv/, data/raw/, models/*.pt, etc.);
# the worldcup paths are then explicitly re-included.

# 1) ignore everything at the root
/*

# 2) re-include the worldcup deployment
!/.gitignore
!/.github/
!/config.py
!/web/
!/src/
!/data/

# 3) within src/, keep only the worldcup pipeline (not the accuracy-model code)
/src/*
!/src/worldcup_fetch.py
!/src/worldcup_standings.py
!/src/worldcup_predict.py

# 4) within data/, keep only the worldcup data
/data/*
!/data/worldcup/

# never track caches / OS cruft, even under re-included dirs
__pycache__/
*.pyc
.DS_Store
